{
  "name": "admin",
  "version": "1.0.0",
  "author": {
    "name": "Leryn",
    "email": "pinktin@sina.com",
    "url": "https://gitee.com/leryn"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "reinstall": "rimraf pnpm-lock.yaml && rimraf package.lock.json && pnpm run clean && pnpm run bootstrap",
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vue-tsc --noEmit && vite build && esno ../build/postBuild.ts",
    "preview": "pnpm run build && vite preview",
    "preview:dist": "vite preview",
    "serve": "vite preview",
    "format": "prettier --config .prettierrc.js --write {src,build,mock,test}/**/*.{ts,js,scss,less,vue} --write vite.config.ts",
    "docker:deploy": "bash ./build/docker/docker-deploy.sh"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@ant-design/colors": "^6.0.0",
    "@ant-design/icons-vue": "^6.0.1",
    "@leryn/utils": "workspace:^1.0.0",
    "ant-design-vue": "^3.0.0-alpha.14",
    "axios": "^0.24.0",
    "crypto-js": "^4.1.1",
    "echarts": "^5.2.2",
    "lodash-es": "^4.17.21",
    "moment": "^2.29.1",
    "pinia": "^2.0.6",
    "qrcode": "^1.5.0",
    "qs": "^6.10.2",
    "sortablejs": "^1.14.0",
    "vue": "^3.2.23",
    "vue-i18n": "^9.1.9",
    "vue-router": "^4.0.12",
    "xterm": "^4.15.0",
    "xterm-addon-attach": "^0.6.0",
    "xterm-addon-fit": "^0.5.0"
  },
  "devDependencies": {
    "@leryn/settings": "workspace:^1.0.0",
    "@leryn/types": "workspace:^1.0.0",
    "@types/crypto-js": "^4.0.2",
    "@types/lodash-es": "^4.17.5",
    "@types/mockjs": "^1.0.4",
    "@types/node": "^16.11.11",
    "@types/qrcode": "^1.4.2",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.6.0",
    "@vitejs/plugin-vue": "^1.3.0",
    "@vitejs/plugin-vue-jsx": "^1.3.1",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/runtime-core": "^3.2.24",
    "autoprefixer": "^10.4.1",
    "babel-plugin-import": "^1.13.3",
    "chalk": "^5.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0",
    "eslint": "^8.3.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vue": "^8.1.1",
    "esno": "^0.12.1",
    "less": "^4.1.2",
    "mockjs": "^1.1.0",
    "postcss": "^8.4.5",
    "prettier": "^2.5.0",
    "rimraf": "^3.0.2",
    "rollup": "^2.61.1",
    "rollup-plugin-analyzer": "^4.0.0",
    "rxjs": "^7.4.0",
    "sass": "^1.48.0",
    "tslib": "^2.3.1",
    "typescript": "^4.5.2",
    "unplugin-vue-components": "^0.17.13",
    "vite": "^2.7.0",
    "vite-plugin-compression": "^0.3.6",
