{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "modeResolution": "node",
    "strict": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "skipLibCheck": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "scripthost"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "types/*.d.ts",
    "types/router.ts",
    "types/global.ts",
    "types/http.ts",
    "types/ref.ts",
    "types/storage.ts",
    "types/tsx.ts",
    "types/vue.ts",
    "types/event.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js",
  ]
}